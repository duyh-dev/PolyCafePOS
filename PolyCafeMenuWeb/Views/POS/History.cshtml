@model IEnumerable<PolyCafeMenuWeb.Models.Order>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
    Layout = "~/Views/POS/_Layout.cshtml";

    var totalProcessed = Model.Where(o => o.Status != "Cancelled").Sum(o => o.TotalAmount);
    var totalOrders = Model.Count();
    var completedOrders = Model.Count(o => o.Status == "Completed");
    var pendingOrders = Model.Count(o => o.Status == "Pending");
}

@section Styles {
    <style>
        /* ========================================
           HISTORY PAGE
           ======================================== */
        .history-container {
            padding: 1.5rem 2rem;
            width: 100%;
            overflow-y: auto;
        }

        /* Summary Header */
        .history-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 2rem;
            gap: 1.5rem;
        }

        .history-title h3 {
            font-size: 1.35rem;
            font-weight: 800;
            margin-bottom: 0.25rem;
            color: var(--text-main);
        }

        .history-title p {
            color: var(--text-muted);
            font-size: 0.9rem;
            font-weight: 500;
            margin: 0;
        }

        /* Stats Cards */
        .stats-row {
            display: flex;
            gap: 12px;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 0.85rem 1.25rem;
            text-align: center;
            min-width: 130px;
        }

        .stat-card .stat-label {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 4px;
        }

        .stat-card .stat-value {
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--primary);
        }

        .stat-card.stat-orders .stat-value {
            color: var(--text-main);
        }

        .stat-card.stat-pending .stat-value {
            color: var(--warning);
        }

        /* ========================================
           ORDER CARDS — Modern, Clean
           ======================================== */
        .order-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            margin-bottom: 1rem;
            transition: box-shadow 0.2s, border-color 0.2s;
        }

        .order-card:hover {
            border-color: rgba(4, 140, 115, 0.25);
            box-shadow: 0 4px 16px rgba(4, 140, 115, 0.08);
        }

        .order-header {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .order-code {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .order-code .order-hash {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--primary);
            background: var(--primary-light);
            width: 24px;
            height: 24px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
        }

        .order-time {
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .order-time i {
            font-size: 0.8rem;
            color: var(--text-light);
        }

        /* Order Body */
        .order-body {
            padding: 1rem 1.5rem;
        }

        .order-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 0.6rem 0;
        }

        .order-item + .order-item {
            border-top: 1px solid var(--border-light);
        }

        .item-left {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            flex-grow: 1;
        }

        .item-qty {
            font-weight: 700;
            color: var(--primary);
            font-size: 0.9rem;
            min-width: 28px;
            flex-shrink: 0;
        }

        .item-details {
            flex-grow: 1;
        }

        .item-name {
            font-weight: 600;
            color: var(--text-main);
            font-size: 0.9rem;
            line-height: 1.3;
        }

        .item-meta {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-top: 1px;
        }

        .item-topping {
            font-size: 0.78rem;
            color: var(--primary);
            margin-top: 2px;
        }

        .item-price {
            font-weight: 700;
            font-size: 0.9rem;
            min-width: 90px;
            text-align: right;
            color: var(--text-main);
            flex-shrink: 0;
        }

        /* Order Footer */
        .order-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Status Badges */
        .status-badge {
            padding: 0.35rem 0.85rem;
            border-radius: var(--radius-pill);
            font-weight: 700;
            font-size: 0.78rem;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            text-transform: capitalize;
        }

        .status-badge i {
            font-size: 0.7rem;
        }

        .status-Pending {
            background: var(--warning-bg);
            color: #B45309;
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        .status-Completed {
            background: var(--success-bg);
            color: #047857;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .status-Cancelled {
            background: var(--danger-bg);
            color: #DC2626;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .order-total-area {
            text-align: right;
        }

        .order-total-label {
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-bottom: 2px;
        }

        .order-total-amount {
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--primary);
        }

        /* ========================================
           EMPTY STATE
           ======================================== */
        .empty-history {
            text-align: center;
            padding: 4rem 2rem;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
        }

        .empty-history-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: var(--bg-main);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.25rem;
        }

        .empty-history-icon i {
            font-size: 2rem;
            color: var(--text-light);
        }

        .empty-history h4 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.4rem;
        }

        .empty-history p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .empty-history .btn {
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            border-radius: var(--radius-sm);
        }

        /* ========================================
           STATUS LOCALIZATION HELPER
           ======================================== */
    </style>
}

<div class="history-container">
    <!-- Header with Summary Statistics -->
    <div class="history-header">
        <div class="history-title">
            <h3><i class="fa-solid fa-receipt me-2" style="color: var(--primary);"></i>Lịch sử đơn hàng</h3>
            <p>Các giao dịch trong ngày @DateTime.Now.ToString("dd/MM/yyyy")</p>
        </div>
        <div class="stats-row">
            <div class="stat-card stat-orders">
                <div class="stat-label">Tổng đơn</div>
                <div class="stat-value">@totalOrders</div>
            </div>
            @if (pendingOrders > 0)
            {
                <div class="stat-card stat-pending">
                    <div class="stat-label">Đang xử lý</div>
                    <div class="stat-value">@pendingOrders</div>
                </div>
            }
            <div class="stat-card">
                <div class="stat-label">Doanh thu</div>
                <div class="stat-value">@String.Format("{0:N0}", totalProcessed)₫</div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <!-- Empty State -->
        <div class="empty-history">
            <div class="empty-history-icon">
                <i class="fa-solid fa-receipt"></i>
            </div>
            <h4>Chưa có đơn hàng nào</h4>
            <p>Bạn chưa xử lý đơn hàng nào trong ngày hôm nay.</p>
            <a href="~/POS/Index" class="btn btn-primary">
                <i class="fa-solid fa-cash-register me-2"></i>Bắt đầu bán hàng
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var order in Model)
            {
                <div class="col-lg-6 col-md-12">
                    <div class="order-card">
                        <!-- Order Header -->
                        <div class="order-header">
                            <h4 class="order-code">
                                <span class="order-hash">#</span>
                                @order.OrderCode
                            </h4>
                            <div class="order-time">
                                <i class="fa-regular fa-clock"></i>
                                @order.OrderDate.ToString("HH:mm")
                            </div>
                        </div>

                        <!-- Order Items -->
                        <div class="order-body">
                            @foreach (var detail in order.OrderDetails)
                            {
                                <div class="order-item">
                                    <div class="item-left">
                                        <span class="item-qty">@detail.Quantity×</span>
                                        <div class="item-details">
                                            <div class="item-name">@detail.DrinkNameSnapshot</div>
                                            <div class="item-meta">Size @detail.SizeSnapshot · @String.Format("{0:N0}", detail.PriceSnapshot)₫</div>

                                            @if (detail.OrderDetailToppings.Any())
                                            {
                                                @foreach (var t in detail.OrderDetailToppings)
                                                {
                                                    <div class="item-topping">+ @t.ToppingNameSnapshot (@String.Format("{0:N0}", t.PriceSnapshot)₫)</div>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <div class="item-price">
                                        @String.Format("{0:N0}", detail.SubTotal) ₫
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Order Footer -->
                        <div class="order-footer">
                            <div class="status-badge status-@order.Status">
                                @if (order.Status == "Pending")
                                {
                                    <i class="fa-solid fa-clock"></i>
                                    <span>Đang xử lý</span>
                                }
                                else if (order.Status == "Completed")
                                {
                                    <i class="fa-solid fa-check"></i>
                                    <span>Hoàn thành</span>
                                }
                                else
                                {
                                    <i class="fa-solid fa-xmark"></i>
                                    <span>Đã huỷ</span>
                                }
                            </div>
                            <div class="order-total-area">
                                <div class="order-total-label">Tổng tiền</div>
                                <div class="order-total-amount">@String.Format("{0:N0}", order.TotalAmount) ₫</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
