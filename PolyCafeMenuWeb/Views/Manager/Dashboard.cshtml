@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Manager/_Layout.cshtml";
}

<!-- FILTER -->
<div class="glass-card mb-4">
    <form method="get" asp-action="Dashboard" class="row g-3 align-items-end">

        <div class="col">
            <label class="form-label">Từ ngày</label>
            <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
        </div>

        <div class="col">
            <label class="form-label">Đến ngày</label>
            <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
        </div>

        <div class="col-auto">
            <button type="submit" class="btn btn-primary px-4 w-100">
                <i class="fa-solid fa-filter me-2"></i>Xem thống kê
            </button>
        </div>

    </form>
</div>

<!-- STAT CARDS -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-3 mb-4">

    <div class="col">
        <div class="glass-card stat-card">
            <div class="stat-icon blue"><i class="fa-solid fa-coins"></i></div>
            <div class="stat-details">
                <h4>Doanh thu khoảng</h4>
                <p>@String.Format("{0:N0}", ViewBag.RangeRevenue)₫</p>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="glass-card stat-card">
            <div class="stat-icon blue"><i class="fa-solid fa-dollar-sign"></i></div>
            <div class="stat-details">
                <h4>Doanh thu (khoảng chọn)</h4>
                <p>@String.Format("{0:N0}", ViewBag.SelectedDateRevenue)₫</p>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="glass-card stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-chart-line"></i></div>
            <div class="stat-details">
                <h4>Doanh thu tháng</h4>
                <p>@String.Format("{0:N0}", ViewBag.MonthRevenue)₫</p>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="glass-card stat-card">
            <div class="stat-icon orange"><i class="fa-solid fa-receipt"></i></div>
            <div class="stat-details">
                <h4>Tổng đơn</h4>
                <p>@ViewBag.TotalOrdersOnSelectedDate</p>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="glass-card stat-card">
            <div class="stat-icon purple"><i class="fa-solid fa-coffee"></i></div>
            <div class="stat-details">
                <h4>Tổng món</h4>
                <p>@ViewBag.TotalDrinks</p>
            </div>
        </div>
    </div>

</div>

<!-- CHART + QUICK ACTION -->
<div class="row">

    <!-- CHART -->
    <div class="col-lg-8">
        <div class="glass-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5>Doanh thu từ @ViewBag.StartDate đến @ViewBag.EndDate</h5>
            </div>
            <div style="height: 350px;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>

    <!-- QUICK ACTION -->
    <div class="col-lg-4">
        <div class="glass-card h-100">
            <h5 class="mb-4">Quick Actions</h5>

            <div class="d-grid gap-3">
                <a href="~/Manager/Drinks" class="btn btn-outline-primary text-start py-3 rounded-3">
                    <i class="fa-solid fa-plus text-primary me-2"></i> Add New Drink
                </a>

                <a href="~/Manager/Employees" class="btn btn-outline-primary text-start py-3 rounded-3">
                    <i class="fa-solid fa-user-plus text-primary me-2"></i> Add Employee
                </a>

                <a href="~/Manager/Reports" class="btn btn-outline-primary text-start py-3 rounded-3">
                    <i class="fa-solid fa-download text-primary me-2"></i> Export Report
                </a>
            </div>

        </div>
    </div>

</div>

<!-- TOP 5 -->
<div class="row mt-4">
    <div class="col-lg-12">
        <div class="glass-card">
            <h5 class="mb-4">Top 5 thức uống bán chạy</h5>

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tên thức uống</th>
                        <th>Số lượng bán</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var topDrinks = ViewBag.TopDrinks as IEnumerable<dynamic>;
                        int index = 1;
                    }

                    @if (topDrinks != null && topDrinks.Any())
                    {
                        foreach (var item in topDrinks)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@item.DrinkName</td>
                                <td>@item.TotalQuantity</td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted">
                                Không có dữ liệu
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            var rawChartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartData ?? new List<object>()));

            var labels = rawChartData.map(item => item.Date);
            var data = rawChartData.map(item => item.Revenue);

            var ctx = document.getElementById('revenueChart').getContext('2d');

            var gradient = ctx.createLinearGradient(0, 0, 0, 350);
            gradient.addColorStop(0, 'rgba(46, 125, 50, 0.4)');
            gradient.addColorStop(1, 'rgba(46, 125, 50, 0.0)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: data,
                        backgroundColor: gradient,
                        borderColor: '#2E7D32',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });

        });
    </script>
}