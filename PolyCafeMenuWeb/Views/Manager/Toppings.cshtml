@model IEnumerable<PolyCafeMenuWeb.Models.Topping>

@{
    ViewData["Title"] = "Manage Toppings";
    Layout = "~/Views/Manager/_Layout.cshtml";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0">Product Toppings</h5>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#toppingModal" onclick="resetForm()">
            <i class="fa-solid fa-plus me-2"></i> Add Topping
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th width="50">ID</th>
                    <th width="80">Image</th>
                    <th>Name</th>
                    <th>Extra Price</th>
                    <th width="100">Status</th>
                    <th width="150" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted">#@item.ToppingID</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="rounded-circle" width="40" height="40" style="object-fit:cover" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width:40px;height:40px;opacity:0.5">
                                    <i class="fa-solid fa-ice-cream"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-bold">@item.ToppingName</td>
                        <td class="text-warning fw-bold">+@String.Format("{0:N0}", item.ExtraPrice) ₫</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1">Inactive</span>
                            }
                        </td>
                        <td class="text-end border-end-0">
                            <button class="btn btn-sm btn-outline-light text-primary border-0" 
                                    onclick="editTopping(@item.ToppingID, '@item.ToppingName', @item.ExtraPrice, '@item.ImageUrl', @item.IsActive.ToString().ToLower())"
                                    title="Edit">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            
                            <form asp-action="DeleteTopping" method="post" class="d-inline" onsubmit="return confirm('Delete this topping?');">
                                <input type="hidden" name="id" value="@item.ToppingID" />
                                <button type="submit" class="btn btn-sm btn-outline-light text-danger border-0" title="Delete">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="toppingModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom border-light">
                <h5 class="modal-title" id="modalTitle">Add New Topping</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SaveTopping" method="post">
                <div class="modal-body">
                    <input type="hidden" id="ToppingID" name="ToppingID" value="0" />
                    
                    <div class="mb-3">
                        <label for="ToppingName" class="form-label text-muted">Topping Name</label>
                        <input type="text" class="form-control" id="ToppingName" name="ToppingName" required />
                    </div>

                    <div class="mb-3">
                        <label for="ExtraPrice" class="form-label text-muted">Extra Price (VND)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark text-muted border-light">₫</span>
                            <input type="number" step="1000" min="0" class="form-control" id="ExtraPrice" name="ExtraPrice" required />
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="ImageUrl" class="form-label text-muted">Image URL (Optional)</label>
                        <input type="url" class="form-control" id="ImageUrl" name="ImageUrl" placeholder="https://..." />
                    </div>
                    
                    <div class="form-check form-switch mb-2 pt-2">
                        <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive" value="true" checked>
                        <label class="form-check-label" for="IsActive">Present in Menu</label>
                    </div>
                </div>
                <div class="modal-footer border-top border-light">
                    <button type="button" class="btn bg-transparent text-white" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resetForm() {
            document.getElementById('modalTitle').innerText = 'Add New Topping';
            document.getElementById('ToppingID').value = '0';
            document.getElementById('ToppingName').value = '';
            document.getElementById('ExtraPrice').value = '10000';
            document.getElementById('ImageUrl').value = '';
            document.getElementById('IsActive').checked = true;
        }

        function editTopping(id, name, price, img, active) {
            document.getElementById('modalTitle').innerText = 'Edit Topping';
            document.getElementById('ToppingID').value = id;
            document.getElementById('ToppingName').value = name;
            document.getElementById('ExtraPrice').value = price;
            document.getElementById('ImageUrl').value = img;
            document.getElementById('IsActive').checked = active;
            
            var modal = new bootstrap.Modal(document.getElementById('toppingModal'));
            modal.show();
        }
    </script>
}
