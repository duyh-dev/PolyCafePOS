@model IEnumerable<PolyCafeMenuWeb.Models.Drink>

@{
    ViewData["Title"] = "Manage Drinks";
    Layout = "~/Views/Manager/_Layout.cshtml";
    var categories = ViewBag.Categories as IEnumerable<PolyCafeMenuWeb.Models.Category> ?? new List<PolyCafeMenuWeb.Models.Category>();
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0">Drinks Catalog</h5>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#drinkModal" onclick="resetForm()">
            <i class="fa-solid fa-plus me-2"></i> Add Drink
        </button>
    </div>
    <div class="mb-3 d-flex gap-2">
        <select class="form-select bg-dark text-white border-light" id="categoryFilter" onchange="filterDrinks()" style="width: 180px;">
            <option value="">All</option>
            @foreach (var cat in categories)
            {
                <option value="@cat.CategoryName">@cat.CategoryName</option>
            }
        </select>
    </div>
    <!-- Search Bar -->
    <div class="input-group mb-3">
        <span class="input-group-text bg-dark border-light">
            <i class="fa-solid fa-magnifying-glass text-muted"></i>
        </span>
        <input type="text" class="form-control bg-dark border-light text-white" id="searchInput" placeholder="Tìm kiếm đồ uống theo tên..." oninput="filterDrinks()">
        <button class="btn btn-outline-secondary border-light" type="button" id="clearSearchBtn" onclick="clearSearch()" style="display: none;">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th width="50">ID</th>
                    <th width="80">Image</th>
                    <th>Drink Name</th>
                    <th>Category</th>
                    <th>Variants (Sizes)</th>
                    <th width="100">Status</th>
                    <th width="150" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="drinksTableBody">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted">#@item.DrinkID</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="rounded" width="40" height="40" style="object-fit:cover" />
                            }
                            else
                            {
                                <div class="rounded bg-secondary d-flex align-items-center justify-content-center" style="width:40px;height:40px;opacity:0.3">
                                    <i class="fa-solid fa-coffee text-white"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-bold">@item.DrinkName</td>
                        <td class="text-muted">@(item.Category?.CategoryName ?? "Uncategorized")</td>
                        <td>
                            @if (item.Variants != null && item.Variants.Any())
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach(var v in item.Variants)
                                    {
                                        <span class="badge" style="background: rgba(139, 92, 246, 0.2); color: #c4b5fd; border: 1px solid rgba(139, 92, 246, 0.4);">
                                            @v.SizeName: @String.Format("{0:N0}", v.Price)₫
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted fst-italic small">No variants</span>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-light text-primary border-0" 
                                    onclick="editDrink(@item.DrinkID, '@item.DrinkName', @item.CategoryID, '@item.ImageUrl', @item.IsActive.ToString().ToLower())"
                                    title="Edit">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            
                            <form asp-action="DeleteDrink" method="post" class="d-inline" onsubmit="return confirm('Delete this drink entirely?');">
                                <input type="hidden" name="id" value="@item.DrinkID" />
                                <button type="submit" class="btn btn-sm btn-outline-light text-danger border-0" title="Delete">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="drinkModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom border-light">
                <h5 class="modal-title" id="modalTitle">Add New Drink</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SaveDrink" method="post" id="drinkForm">
                <div class="modal-body">
                    <input type="hidden" id="DrinkID" name="DrinkID" value="0" />
                    
                    <div class="row">
                        <div class="col-md-7">
                            <h6 class="text-primary mb-3 border-bottom border-light pb-2">Basic Info</h6>
                            <div class="mb-3">
                                <label class="form-label text-muted">Drink Name</label>
                                <input type="text" class="form-control" id="DrinkName" name="DrinkName" required />
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label text-muted">Category</label>
                                <select class="form-select" id="CategoryID" name="CategoryID" required>
                                    <option value="">-- Select Category --</option>
                                    @foreach(var cat in categories)
                                    {
                                        <option value="@cat.CategoryID">@cat.CategoryName</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted">Image URL (Optional)</label>
                                <input type="url" class="form-control" id="ImageUrl" name="ImageUrl" placeholder="https://..." />
                            </div>

                            <div class="form-check form-switch pt-2">
                                <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive" value="true" checked>
                                <label class="form-check-label" for="IsActive">Available on Menu</label>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <h6 class="text-primary mb-3 border-bottom border-light pb-2">
                                Variants (Sizes & Prices)
                                <button type="button" class="btn btn-sm btn-outline-primary float-end" onclick="addVariantRow()">
                                    <i class="fa-solid fa-plus"></i> Add
                                </button>
                            </h6>
                            
                            <div id="variantsContainer" class="pe-2" style="max-height: 300px; overflow-y: auto; overflow-x: hidden;">
                                <!-- Variants rows will be added here via JS -->
                            </div>
                            
                            <div id="noVariantsMsg" class="text-center p-3 text-muted small" style="border: 1px dashed rgba(255,255,255,0.1); border-radius: 8px;">
                                Click 'Add' to set sizes and prices for this drink.
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-light">
                    <button type="button" class="btn bg-transparent text-white" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let variantIndex = 0;

        function addVariantRow(id = 0, size = '', price = '') {
            const container = document.getElementById('variantsContainer');
            document.getElementById('noVariantsMsg').style.display = 'none';
            
            const row = document.createElement('div');
            row.className = 'variant-row mb-2 p-2 rounded';
            row.style.backgroundColor = 'rgba(0,0,0,0.2)';
            
            row.innerHTML = `
                <div class="row gx-2 align-items-center">
                    <input type="hidden" name="Variants[${variantIndex}].VariantID" value="${id}" />
                    <input type="hidden" name="Variants[${variantIndex}].IsActive" value="true" />
                    
                    <div class="col-4">
                        <input type="text" class="form-control form-control-sm" name="Variants[${variantIndex}].SizeName" placeholder="Size (eg. M)" value="${size}" required />
                    </div>
                    <div class="col-6">
                        <div class="input-group input-group-sm">
                            <input type="number" class="form-control" name="Variants[${variantIndex}].Price" placeholder="Price" value="${price}" required />
                            <span class="input-group-text bg-dark border-light text-muted">₫</span>
                        </div>
                    </div>
                    <div class="col-2 text-end">
                        <button type="button" class="btn btn-sm btn-danger px-2" onclick="this.closest('.variant-row').remove(); checkEmptyVariants();">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                </div>
            `;
            
            container.appendChild(row);
            variantIndex++;
        }

        function checkEmptyVariants() {
            if (document.querySelectorAll('.variant-row').length === 0) {
                document.getElementById('noVariantsMsg').style.display = 'block';
            }
        }

        function resetForm() {
            document.getElementById('modalTitle').innerText = 'Add New Drink';
            document.getElementById('DrinkID').value = '0';
            document.getElementById('DrinkName').value = '';
            document.getElementById('CategoryID').value = '';
            document.getElementById('ImageUrl').value = '';
            document.getElementById('IsActive').checked = true;
            
            document.getElementById('variantsContainer').innerHTML = '';
            document.getElementById('noVariantsMsg').style.display = 'block';
            variantIndex = 0;
            
            // Add default M size
            addVariantRow(0, 'M', '');
        }

        function editDrink(id, name, catId, img, active) {
            document.getElementById('modalTitle').innerText = 'Edit Drink';
            document.getElementById('DrinkID').value = id;
            document.getElementById('DrinkName').value = name;
            document.getElementById('CategoryID').value = catId;
            document.getElementById('ImageUrl').value = img;
            document.getElementById('IsActive').checked = active;
            
            document.getElementById('variantsContainer').innerHTML = '<div class="text-center p-3 text-muted"><div class="spinner-border spinner-border-sm me-2"></div> Loading variants...</div>';
            document.getElementById('noVariantsMsg').style.display = 'none';
            variantIndex = 0;
            
            // Fetch variants via AJAX
            fetch(`/Manager/GetDrinkVariants?id=${id}`)
                .then(res => res.json())
                .then(data => {
                    document.getElementById('variantsContainer').innerHTML = '';
                    if (data && data.length > 0) {
                        data.forEach(v => addVariantRow(v.variantID, v.sizeName, v.price));
                    } else {
                        checkEmptyVariants();
                    }
                })
                .catch(err => {
                    document.getElementById('variantsContainer').innerHTML = '<div class="text-danger p-2">Failed to load variants</div>';
                });
            
            var modal = new bootstrap.Modal(document.getElementById('drinkModal'));
            modal.show();
        }

        // Search functionality
        function filterDrinks() {
            const query = document.getElementById('searchInput').value.trim().toLowerCase();
            const category = document.getElementById('categoryFilter').value;
            const clearBtn = document.getElementById('clearSearchBtn');
            const tbody = document.getElementById('drinksTableBody');
            const rows = tbody.getElementsByTagName('tr');

            clearBtn.style.display = query.length > 0 ? 'block' : 'none';

            for (let i = 0; i < rows.length; i++) {
                const nameCol = rows[i].getElementsByTagName('td')[2]; // Drink Name
                const categoryCol = rows[i].getElementsByTagName('td')[3]; // Category

                if (nameCol && categoryCol) {
                    const nameText = nameCol.textContent.toLowerCase();
                    const categoryText = categoryCol.textContent.trim();

                    const matchSearch = nameText.includes(query);
                    const matchCategory = category === "" || categoryText === category;

                    if (matchSearch && matchCategory) {
                        rows[i].style.display = '';
                    } else {
                        rows[i].style.display = 'none';
                    }
                }
            }
        }

        function clearSearch() {
            document.getElementById('searchInput').value = '';
            document.getElementById('categoryFilter').value = '';
            document.getElementById('clearSearchBtn').style.display = 'none';
            filterDrinks();
        }
    </script>
}
