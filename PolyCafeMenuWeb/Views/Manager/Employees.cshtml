@model IEnumerable<PolyCafeMenuWeb.Models.Employee>

@{
    ViewData["Title"] = "Manage Employees";
    Layout = "~/Views/Manager/_Layout.cshtml";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0">Staff & Exmployees</h5>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#employeeModal" onclick="resetForm()">
            <i class="fa-solid fa-user-plus me-2"></i> Add Employee
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th width="60">ID</th>
                    <th>Full Name</th>
                    <th>Role</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th width="150" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td class="text-muted">#@emp.EmployeeID</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm me-3 bg-secondary bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold" style="width: 36px; height: 36px">
                                    @emp.FullName?.Substring(0, 1).ToUpper()
                                </div>
                                <span class="fw-bold text-white">@emp.FullName</span>
                            </div>
                        </td>
                        <td>
                            @switch(emp.Role)
                            {
                                case "Manager": <span class="badge bg-primary">Manager</span> break;
                                case "Cashier": <span class="badge bg-info text-dark">Cashier</span> break;
                                case "Barista": <span class="badge bg-warning text-dark">Barista</span> break;
                                default: <span class="badge bg-secondary">@emp.Role</span> break;
                            }
                        </td>
                        <td class="font-monospace text-muted small">@emp.Username</td>
                        <td class="text-muted"><i class="fa-regular fa-envelope small me-1"></i> @emp.Email</td>
                        <td class="text-muted"><i class="fa-solid fa-phone small me-1"></i> @(emp.Phone ?? "N/A")</td>
                        <td>
                            @if (emp.IsActive)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-light text-primary border-0" 
                                    onclick="editEmp(@emp.EmployeeID, '@emp.FullName', '@emp.Username', '@emp.Password', '@emp.Role', '@emp.Email', '@(emp.Phone ?? "")', @emp.IsActive.ToString().ToLower())"
                                    title="Edit">
                                <i class="fa-solid fa-user-pen"></i>
                            </button>
                            
                            @if (emp.Username != Context.Session.GetString("Username"))
                            {
                                <form asp-action="DeleteEmployee" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this employee account?');">
                                    <input type="hidden" name="id" value="@emp.EmployeeID" />
                                    <button type="submit" class="btn btn-sm btn-outline-light text-danger border-0" title="Delete">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="employeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom border-light">
                <h5 class="modal-title" id="modalTitle">Register Employee</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SaveEmployee" method="post">
                <div class="modal-body">
                    <input type="hidden" id="EmployeeID" name="EmployeeID" value="0" />
                    
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label text-muted">Full Name</label>
                            <input type="text" class="form-control" id="FullName" name="FullName" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Username</label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-light text-muted"><i class="fa-solid fa-at"></i></span>
                                <input type="text" class="form-control" id="Username" name="Username" required />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-light text-muted"><i class="fa-solid fa-key"></i></span>
                                <input type="text" class="form-control" id="Password" name="Password" required />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Role Assigned</label>
                            <select class="form-select" id="Role" name="Role" required>
                                <option value="Cashier">Cashier</option>
                                <option value="Barista">Barista</option>
                                <option value="Manager">Manager</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-light text-muted"><i class="fa-regular fa-envelope"></i></span>
                                <input type="email" class="form-control" id="Email" name="Email" required />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Phone No</label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-light text-muted"><i class="fa-solid fa-phone"></i></span>
                                <input type="tel" class="form-control" id="Phone" name="Phone" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-check form-switch pt-2">
                        <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive" value="true" checked>
                        <label class="form-check-label" for="IsActive">Account Enabled</label>
                    </div>
                </div>
                <div class="modal-footer border-top border-light">
                    <button type="button" class="btn bg-transparent text-white" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Save Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resetForm() {
            document.getElementById('modalTitle').innerText = 'Register Employee';
            document.getElementById('EmployeeID').value = '0';
            document.getElementById('FullName').value = '';
            document.getElementById('Username').value = '';
            document.getElementById('Password').value = '';
            document.getElementById('Role').value = 'Cashier';
            document.getElementById('Email').value = '';
            document.getElementById('Phone').value = '';
            document.getElementById('IsActive').checked = true;
        }

        function editEmp(id, name, username, password, role, email, phone, active) {
            document.getElementById('modalTitle').innerText = 'Edit Employee details';
            document.getElementById('EmployeeID').value = id;
            document.getElementById('FullName').value = name;
            document.getElementById('Username').value = username;
            document.getElementById('Password').value = password;
            document.getElementById('Role').value = role;
            document.getElementById('Email').value = email;
            document.getElementById('Phone').value = phone;
            document.getElementById('IsActive').checked = active;
            
            var modal = new bootstrap.Modal(document.getElementById('employeeModal'));
            modal.show();
        }
    </script>
}
