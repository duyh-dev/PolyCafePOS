@model IEnumerable<PolyCafeMenuWeb.Models.Order>

@{
    ViewData["Title"] = "Barista Queue";
    Layout = null; // Independent Layout for Barista
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PolyCafe - Barista Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            /* Vintage Nature Theme Variables */
            --bg-page: #F5F2EB; /* Warm paper/vintage background */
            --bg-card: #FFFFFF; /* Clean secondary color */
            --text-main: #1D332B; /* Dark vintage forest text */
            --text-muted: #5C7065;
            --accent-primary: #048C73; /* Primary Brand Color */
            --accent-hover: #036b58;
            --border-custom: rgba(4, 140, 115, 0.2);
            /* SVG Wood Grain Texture */
            --wood-texture: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.02' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' fill='%23048C73' opacity='0.03' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            
            --bs-primary: #048C73;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-page);
            background-image: var(--wood-texture);
            color: var(--text-main);
            min-height: 100vh;
        }

        /* Typography */
        h1, h2, h3, h4, h5, h6, .fw-bold { color: var(--text-main) !important; letter-spacing: -0.02em; }
        .text-white { color: #FFFFFF !important; }
        .text-muted { color: var(--text-muted) !important; }

        .barista-header {
            background-color: var(--bg-card);
            border-bottom: 2px solid var(--accent-primary);
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        }
        
        /* Barista Header text overrides */
        .barista-header .text-white { color: var(--text-main) !important; }
        .barista-header .text-muted { color: var(--text-muted) !important; }

        .queue-container {
            padding: 2.5rem;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.8rem;
            align-items: start;
        }

        .ticket-card {
            background: #FFFFFF;
            border: 1px solid var(--border-custom);
            border-top: 5px solid #F59E0B; /* Pending color - warm yellow/orange */
            border-radius: 12px;
            box-shadow: 0 6px 15px rgba(4, 140, 115, 0.05);
            animation: slideIn 0.3s ease-out;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .ticket-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(4, 140, 115, 0.1);
        }

        /* Subtle ticket pattern */
        .ticket-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: radial-gradient(#048C73 1px, transparent 1px);
            background-size: 20px 20px;
            opacity: 0.03;
            pointer-events: none;
        }

        @@keyframes slideIn {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .ticket-header {
            padding: 1.25rem;
            border-bottom: 2px dashed rgba(4, 140, 115, 0.15);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: rgba(4, 140, 115, 0.02);
        }

        .ticket-id {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--text-main) !important;
            margin: 0;
            font-family: monospace;
        }

        .ticket-time {
            background: rgba(245, 158, 11, 0.15);
            color: #d97706;
            padding: 0.3rem 0.6rem;
            border-radius: 8px;
            font-weight: 700;
            font-size: 0.95rem;
        }

        .time-elapsed {
            font-size: 0.85rem;
            font-weight: 600;
            display: block;
            text-align: right;
            margin-top: 4px;
            color: var(--text-muted);
        }

        .time-elapsed.urgent {
            color: #d9534f;
            font-weight: bold;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.7; }
            100% { opacity: 1; }
        }

        .ticket-body {
            padding: 1.25rem;
        }

        .drink-item {
            margin-bottom: 1.2rem;
            padding-bottom: 1.2rem;
            border-bottom: 1px solid var(--border-custom);
        }

        .drink-item:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: none;
        }

        .qty-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-page);
            border: 2px solid var(--accent-primary);
            color: var(--accent-primary);
            width: 32px;
            height: 32px;
            font-weight: 800;
            font-size: 1.1rem;
            border-radius: 8px;
            margin-right: 12px;
        }

        .drink-name {
            font-weight: 700;
            font-size: 1.15rem;
            color: var(--text-main);
            margin-bottom: 2px;
        }

        .drink-meta {
            margin-left: 44px;
            font-size: 0.95rem;
            color: var(--text-muted);
        }
        
        /* Overriding info text in vintage theme */
        .text-info { color: #007799 !important; }

        .topping-tag {
            display: inline-block;
            background: var(--bg-page);
            color: var(--text-muted);
            padding: 0.2rem 0.6rem;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-top: 6px;
            margin-right: 6px;
            border: 1px solid var(--border-custom);
        }

        .ticket-footer {
            padding: 1.2rem;
            background: rgba(4, 140, 115, 0.03);
            border-top: 1px solid var(--border-custom);
            display: flex;
            gap: 10px;
        }

        .btn-complete {
            background-color: var(--accent-primary);
            border: none;
            flex-grow: 1;
            padding: 0.8rem;
            font-weight: 700;
            border-radius: 8px;
            color: #FFFFFF;
            transition: all 0.2s ease;
            box-shadow: 0 4px 10px rgba(4, 140, 115, 0.2);
        }
        
        .btn-complete:hover {
            background-color: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(4, 140, 115, 0.3);
        }
        
        .btn-complete:active { transform: scale(0.98); }

        /* Loader Overlay */
        .processing-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(4px);
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }
        
        .ticket-card.processing .processing-overlay {
            opacity: 1;
            pointer-events: all;
        }
        
        .ticket-card.completed {
            border-top-color: var(--accent-primary);
            transform: scale(0.9) translateY(50px);
            opacity: 0;
            transition: all 0.5s ease-in;
        }
        
        /* Avatar specific */
        .bg-primary { background-color: var(--accent-primary) !important; color: white !important; }
    </style>
</head>
<body>
    <header class="barista-header d-flex justify-content-between align-items-center">
        <h2 class="mb-0 fw-bold" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            <i class="fa-solid fa-fire-burner me-2"></i> Kitchen Display System
        </h2>
        
        <div class="d-flex align-items-center gap-4">
            <div class="text-end text-muted">
                <div class="small fw-bold text-uppercase">Pending Orders</div>
                <div class="fs-4 fw-bold text-white">@Model.Count()</div>
            </div>
            
            <div class="d-flex align-items-center gap-3 ps-4" style="border-left: 1px solid rgba(255,255,255,0.1)">
                <div class="text-end">
                    <div class="fw-bold">@Context.Session.GetString("FullName")</div>
                    <div class="small text-muted">Barista Station</div>
                </div>
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px">
                    @Context.Session.GetString("FullName")?.Substring(0,1).ToUpper()
                </div>
                <a href="~/Auth/Logout" class="text-muted fs-5 ms-2"><i class="fa-solid fa-sign-out-alt"></i></a>
            </div>
        </div>
    </header>

    @if (!Model.Any())
    {
        <div class="d-flex flex-column align-items-center justify-content-center" style="height: calc(100vh - 100px); opacity: 0.5">
            <i class="fa-solid fa-mug-hot fa-4x mb-4 text-muted"></i>
            <h3 class="fw-bold">No Pending Orders</h3>
            <p class="text-muted">Take a break, queue is empty!</p>
        </div>
    }
    else
    {
        <div class="queue-container">
            @foreach (var order in Model)
            {
                <div class="ticket-card" id="ticket-@order.OrderID" data-time="@order.OrderDate.ToString("O")">
                    <div class="processing-overlay">
                        <i class="fa-solid fa-check-circle text-success fa-3x mb-2"></i>
                        <h5 class="fw-bold text-success">Completed!</h5>
                    </div>
                    
                    <div class="ticket-header">
                        <h3 class="ticket-id">#@order.OrderCode.Substring(order.OrderCode.Length - 3)</h3>
                        <div class="text-end">
                            <div class="ticket-time"><i class="fa-regular fa-clock me-1"></i> @order.OrderDate.ToString("HH:mm")</div>
                            <span class="time-elapsed" id="timer-@order.OrderID">0m ago</span>
                        </div>
                    </div>
                    
                    <div class="ticket-body">
                        @foreach (var item in order.OrderDetails)
                        {
                            <div class="drink-item">
                                <div class="d-flex align-items-start">
                                    <span class="qty-badge">@item.Quantity</span>
                                    <div>
                                        <div class="drink-name">@item.DrinkNameSnapshot</div>
                                        <div class="drink-meta fw-bold text-info">Size: @item.SizeSnapshot</div>
                                        
                                        @if (item.OrderDetailToppings.Any())
                                        {
                                            <div class="drink-meta mt-1">
                                                @foreach (var t in item.OrderDetailToppings)
                                                {
                                                    <span class="topping-tag">+ @t.ToppingNameSnapshot</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    
                    @if (!string.IsNullOrEmpty(order.Note))
                    {
                        <div class="px-4 pb-3" style="margin-top: -10px">
                            <div class="p-2 rounded" style="background: rgba(245, 158, 11, 0.1); border: 1px dashed rgba(245, 158, 11, 0.3);">
                                <i class="fa-solid fa-message" style="color: #d97706;"></i> 
                                <span class="fw-bold small" style="color: #92400e;">@order.Note</span>
                            </div>
                        </div>
                    }

                    <div class="ticket-footer">
                        <button class="btn btn-complete" onclick="markCompleted(@order.OrderID)">
                            <i class="fa-solid fa-check-double me-2"></i> Mark Ready
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $(document).ready(function() {
            // Auto reload page every 30 seconds to fetch new orders
            setInterval(function() {
                location.reload();
            }, 30000);

            // Update timers every minute
            updateTimers();
            setInterval(updateTimers, 60000);
        });

        function updateTimers() {
            const now = new Date();
            $('.ticket-card').each(function() {
                const orderTimeStr = $(this).data('time');
                if (!orderTimeStr) return;
                
                const orderTime = new Date(orderTimeStr);
                const diffMs = now - orderTime;
                const diffMins = Math.floor(diffMs / 60000);
                
                const timerEl = $(this).find('.time-elapsed');
                timerEl.text(diffMins + 'm ago');
                
                // Highlight if waiting too long (>10 mins)
                if (diffMins >= 10) {
                    timerEl.addClass('urgent');
                    $(this).css('border-top-color', '#ef4444'); // Red border for delayed
                }
            });
        }

        function markCompleted(orderId) {
            const ticket = $(`#ticket-${orderId}`);
            
            // Show processing state visually immediately
            ticket.addClass('processing');
            
            $.post('/Barista/MarkCompleted', { id: orderId }, function(res) {
                if (res.success) {
                    setTimeout(() => {
                        ticket.addClass('completed');
                        setTimeout(() => {
                            ticket.remove();
                            // If no tickets left, reload to show empty state
                            if ($('.ticket-card').length === 0) {
                                location.reload();
                            }
                        }, 500); // Wait for transition
                    }, 800); // Let them see the green check mark
                } else {
                    ticket.removeClass('processing');
                    alert(res.message);
                }
            }).fail(function() {
                ticket.removeClass('processing');
                alert("Network error updating order.");
            });
        }
    </script>
</body>
</html>
